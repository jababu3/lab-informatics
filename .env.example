# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USERNAME=labuser
MONGO_PASSWORD=change_me_strong_password

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_generate_with_secrets_token_hex_32
JWT_EXPIRE_MINUTES=480

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Ollama (AI Scientist agent) ───────────────────────────────────────────────
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=mistral:7b

# ── Agent auth (optional) ─────────────────────────────────────────────────────
# JWT token for the AI Scientist to post ELN entries. Leave blank to disable.
AGENT_JWT_TOKEN=
